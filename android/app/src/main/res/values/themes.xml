<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Tema mínimo de platform para Activities Compose-only.
      O visual real é controlado por CifrasTheme em ui/theme/Theme.kt.
    -->
    <style name="Theme.Cifras" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <!--
      Splash screen via androidx.core.splashscreen (Android 12+ nativo,
      backport até API 28). Só fundo verde sólido — sem ícone na splash
      nativa, porque a API mascara o ícone em viewport circular e cortava
      o logo. Logo + slogan vêm pelo overlay Compose em MainActivity, com
      fade suave, garantindo aparência consistente em todas as APIs.
    -->
    <style name="Theme.Cifras.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Cifras</item>
    </style>
</resources>
