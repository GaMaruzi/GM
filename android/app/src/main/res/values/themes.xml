<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Tema mínimo de platform para Activities Compose-only.
      O visual real é controlado por CifrasTheme em ui/theme/Theme.kt.
      windowBackground voltou ao default Material (branco) pra evitar que
      as transições entre telas Compose ganhem fundo verde.
    -->
    <style name="Theme.Cifras" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <!--
      Splash screen via androidx.core.splashscreen (Android 12+ nativo,
      backport até API 28). O ícone branco aparece sobre o fundo verde
      desde o primeiro frame da Activity. A safe zone circular da API
      (~160dp interna num viewport 240dp) é respeitada pelo splash_logo.
      Slogan vem pelo overlay Compose em MainActivity, instantâneo
      (EnterTransition.None) — sem fade pra evitar atraso visual.
    -->
    <style name="Theme.Cifras.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Cifras</item>
        <item name="android:windowBackground">@color/splash_background</item>
    </style>
</resources>
