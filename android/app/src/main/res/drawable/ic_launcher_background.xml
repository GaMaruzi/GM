<?xml version="1.0" encoding="utf-8"?>
<!-- Tap Cifras — background: gradiente violeta diagonal + glow radial.
     Spec em docs/design/App Icon.html. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- gradiente principal: 0% #5B43A6 → 55% #3A2E5C → 100% #241B3D -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:type="linear">
                <item android:offset="0.0" android:color="#5B43A6" />
                <item android:offset="0.55" android:color="#3A2E5C" />
                <item android:offset="1.0" android:color="#241B3D" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- glow radial sutil no canto superior esquerdo -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:centerX="36.72" android:centerY="32.4"
                android:gradientRadius="86.4"
                android:type="radial">
                <item android:offset="0.0" android:color="#8C7A5CD0" />
                <item android:offset="1.0" android:color="#007A5CD0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
