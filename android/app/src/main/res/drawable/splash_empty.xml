<?xml version="1.0" encoding="utf-8"?>
<!-- Drawable transparente usado como windowSplashScreenAnimatedIcon.
     A SplashScreen API exige um ícone; passar este vector vazio faz a
     splash nativa renderizar apenas o fundo verde, sem ícone. O ícone
     "real" aparece pelo overlay Compose (SplashOverlay em MainActivity)
     junto do slogan — evitando o efeito de "duas telas separadas". -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#00000000"
        android:pathData="M0,0h108v108h-108z" />
</vector>
