        <path
            android:pathData="M29,60 a11,9 0 1,0 22,0 a11,9 0 1,0 -22,0"
            android:fillColor="#FFFFFFFF" />
    </group>

    <!-- Haste da nota -->
    <path
        android:pathData="M49,32.5 L54.5,32.5 A2.5,2.5 0 0,1 54.5,62 L49,62 Z"
        android:fillColor="#FFFFFFFF" />

