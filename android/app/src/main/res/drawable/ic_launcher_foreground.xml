        android:pathData="M54.5,30 C64.5,32.5 70.5,39 69,48 C68.6,50.4 67.4,52.4 65.8,54 C67,51.6 67.2,49 66.2,46.4 C64.2,41.2 59.2,38.2 54.5,37.2 Z"
