        android:pathData="M40,60 m-23,0 a23,23 0 1,0 46,0 a23,23 0 1,0 -46,0"
        android:strokeColor="#29FFFFFF"
        android:strokeWidth="3"
        android:fillColor="#00000000" />

    <!-- Cabeça da nota: elipse 11×9 em (40,60) rotacionada -22° -->
