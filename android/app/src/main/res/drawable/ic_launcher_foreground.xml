<?xml version="1.0" encoding="utf-8"?>
<!-- Tap Cifras — foreground: nota colcheia branca + ondas de "tap" concêntricas.
     Spec em docs/design/App Icon.html. Zona segura central 66dp. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Tap ripples (círculos concêntricos translúcidos) -->
    <path
        android:pathData="M40,60 m-15,0 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0"
        android:strokeColor="#4DFFFFFF"
        android:strokeWidth="3"
        android:fillColor="#00000000" />
